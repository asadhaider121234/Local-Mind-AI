<Window x:Class="DocMind.Views.Dialogs.SummaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Summary" Height="450" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceSubtleBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFont}"
        WindowStyle="None" AllowsTransparency="True">
    
    <Window.Resources>
        <Style x:Key="RoundedWindow" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource RoundedWindow}" Margin="10">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="AI Document Summary" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock x:Name="FileNameText" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="SummaryText" 
                           TextWrapping="Wrap" 
                           LineHeight="24" 
                           FontSize="14" 
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </ScrollViewer>

            <!-- Footer -->
            <Button Grid.Row="2" Content="Close" 
                    HorizontalAlignment="Right" Width="100" Height="36"
                    Style="{StaticResource PrimaryButton}" 
                    Margin="0,24,0,0"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
