<Page x:Class="DocMind.Views.Pages.Page_Evaluation"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:DocMind.ViewModels"
      xmlns:local="clr-namespace:DocMind.Views"
      mc:Ignorable="d" 
      d:DesignHeight="1200" d:DesignWidth="1100"
      Title="Performance Evaluation"
      FontFamily="{StaticResource AppFont}">

    <Page.DataContext>
        <vm:EvaluationViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Metric Value Style -->
        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- Metric Label Style -->
        <Style x:Key="MetricLabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Trend Style -->
        <Style x:Key="TrendText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <!-- Table Header Style -->
        <Style x:Key="TableHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="Margin" Value="12,8"/>
        </Style>

        <!-- Table Cell Style -->
        <Style x:Key="TableCellText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="12,12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ TOP BAR ═══════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource TopBarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1"
                Padding="32,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Performance Evaluation" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Benchmark results across 100 test queries" FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="{Binding LastRunText, StringFormat='Last run: {0}'}" 
                               VerticalAlignment="Center" Margin="0,0,24,0"
                               Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13"/>
                    <Button Content="Run Benchmark" Style="{StaticResource PrimaryButton}"
                            Padding="24,10" Command="{Binding RunBenchmarkCommand}"
                            IsEnabled="{Binding IsNotRunning}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ CONTENT ═══════════════ -->
        <ScrollViewer Grid.Row="1" Style="{StaticResource SlimScrollViewer}" Padding="32">
            <StackPanel>

                <!-- RUNNING STATE PROGRESS -->
                <Border Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,32" Style="{StaticResource CardBorder}"
                        BorderBrush="{DynamicResource AccentBrush}" Background="{DynamicResource AccentSubtleBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Running 100 benchmark queries..." FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15"/>
                            <TextBlock Text="{Binding CurrentQuery}" FontSize="13" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,16"/>
                            <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="10" 
                                         Background="#1E293B" Foreground="{DynamicResource AccentBrush}">
                                <ProgressBar.Template>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5"/>
                                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" 
                                                    HorizontalAlignment="Left" CornerRadius="5"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding ProgressValue, StringFormat='{}{0} / 100'}"
                                   FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="24,0,0,0"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Grid>
                </Border>

                <!-- SECTION 1: KEY METRICS -->
                <Grid Margin="0,0,0,32" Visibility="{Binding IsNotRunning, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding Precision, StringFormat={}{0:F2}}" Style="{StaticResource MetricValueText}"/>
                            <TextBlock Text="Precision@5" Style="{StaticResource MetricLabelText}"/>
                            <TextBlock Text="↑ Good" Style="{StaticResource TrendText}" Foreground="{DynamicResource StatusGreenBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding Recall, StringFormat={}{0:F2}}" Style="{StaticResource MetricValueText}"/>
                            <TextBlock Text="Recall@5" Style="{StaticResource MetricLabelText}"/>
                            <TextBlock Text="↑ Good" Style="{StaticResource TrendText}" Foreground="{DynamicResource StatusGreenBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="0,0,16,0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding MRR, StringFormat={}{0:F2}}" Style="{StaticResource MetricValueText}"/>
                            <TextBlock Text="MRR" Style="{StaticResource MetricLabelText}"/>
                            <TextBlock Text="↑ Good" Style="{StaticResource TrendText}" Foreground="{DynamicResource StatusGreenBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding AvgLatency, StringFormat={}{0:F1}s}" Style="{StaticResource MetricValueText}"/>
                            <TextBlock Text="Avg Latency" Style="{StaticResource MetricLabelText}"/>
                            <TextBlock Text="↓ Fast" Style="{StaticResource TrendText}" Foreground="{DynamicResource StatusGreenBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- SECTION 2: LATENCY BREAKDOWN -->
                <Border Margin="0,0,0,32" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Query Latency Breakdown (avg per query)" FontSize="18" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24"/>
                        
                        <!-- Embedding Bar -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Embedding" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Rectangle Grid.Column="1" HorizontalAlignment="Left" Height="12" RadiusX="6" RadiusY="6" Fill="#4F8EF7"
                                       Width="{Binding EmbeddingWidth}"/>
                            <TextBlock Grid.Column="2" Text="0.2s" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>

                        <!-- Retrieval Bar -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FAISS Retrieval" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Rectangle Grid.Column="1" HorizontalAlignment="Left" Height="12" RadiusX="6" RadiusY="6" Fill="#06B6D4"
                                       Width="{Binding RetrievalWidth}"/>
                            <TextBlock Grid.Column="2" Text="0.4s" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>

                        <!-- Generation Bar -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="LLM Generation" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Rectangle Grid.Column="1" HorizontalAlignment="Left" Height="12" RadiusX="6" RadiusY="6" Fill="#8B5CF6"
                                       Width="{Binding GenerationWidth}"/>
                            <TextBlock Grid.Column="2" Text="1.3s" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>
                        
                        <Border Height="1" Background="{DynamicResource BorderDefaultBrush}" Margin="0,16,0,16"/>
                        <TextBlock Text="Total Latency: 1.9s" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <!-- SECTION 3: SEARCH COMPARISON -->
                <TextBlock Text="Semantic Search (BGE+FAISS) vs Keyword Search (BM25)" FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Semantic Column -->
                    <Border Grid.Column="0" Margin="0,0,12,0" Style="{StaticResource CardBorder}" BorderBrush="{DynamicResource StatusGreenBrush}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Semantic Search" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Border Background="#166534" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                    <TextBlock Text="✓ WINNER" FontSize="10" FontWeight="Bold" Foreground="#4ADE80"/>
                                </Border>
                            </Grid>
                            
                            <Grid Margin="0,8">
                                <TextBlock Text="Precision@5" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="0.87" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource StatusGreenBrush}"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"/>
                            <Grid Margin="0,8">
                                <TextBlock Text="Recall@5" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="0.79" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource StatusGreenBrush}"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"/>
                            <Grid Margin="0,8">
                                <TextBlock Text="MRR" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="0.83" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource StatusGreenBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- BM25 Column -->
                    <Border Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="BM25 Keyword Search" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            
                            <Grid Margin="0,8">
                                <TextBlock Text="Precision@5" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="0.61" HorizontalAlignment="Right" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"/>
                            <Grid Margin="0,8">
                                <TextBlock Text="Recall@5" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="0.54" HorizontalAlignment="Right" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"/>
                            <Grid Margin="0,8">
                                <TextBlock Text="MRR" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="0.58" HorizontalAlignment="Right" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- SECTION 4: INDEXING PERFORMANCE -->
                <TextBlock Text="FAISS Index Memory &amp; Speed" FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                
                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Headers -->
                        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12,0,0,0"/>
                        <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource SurfaceElevatedBrush}"/>
                        <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource SurfaceElevatedBrush}"/>
                        <Border Grid.Row="0" Grid.Column="3" Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="0,12,0,0"/>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Chunks" Style="{StaticResource TableHeaderText}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Flat Index" Style="{StaticResource TableHeaderText}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="IVFFlat" Style="{StaticResource TableHeaderText}"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="IVFFlat+PQ" Style="{StaticResource TableHeaderText}"/>

                        <!-- Row 1 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="1,000" Style="{StaticResource TableCellText}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="4 MB" Style="{StaticResource TableCellText}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="3 MB" Style="{StaticResource TableCellText}"/>
                        <Border Grid.Row="1" Grid.Column="3" Background="#166534" Opacity="0.1"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="1 MB" Style="{StaticResource TableCellText}" Foreground="{DynamicResource StatusGreenBrush}" FontWeight="Bold"/>

                        <!-- Row 2 -->
                        <Border Grid.Row="2" Grid.ColumnSpan="4" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="10,000" Style="{StaticResource TableCellText}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="38 MB" Style="{StaticResource TableCellText}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="28 MB" Style="{StaticResource TableCellText}"/>
                        <Border Grid.Row="2" Grid.Column="3" Background="#166534" Opacity="0.1"/>
                        <TextBlock Grid.Row="2" Grid.Column="3" Text="8 MB" Style="{StaticResource TableCellText}" Foreground="{DynamicResource StatusGreenBrush}" FontWeight="Bold"/>

                        <!-- Row 3 -->
                        <Border Grid.Row="3" Grid.ColumnSpan="4" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="100,000" Style="{StaticResource TableCellText}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="380 MB" Style="{StaticResource TableCellText}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="260 MB" Style="{StaticResource TableCellText}"/>
                        <Border Grid.Row="3" Grid.Column="3" Background="#166534" Opacity="0.1" CornerRadius="0,0,12,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="3" Text="72 MB" Style="{StaticResource TableCellText}" Foreground="{DynamicResource StatusGreenBrush}" FontWeight="Bold"/>
                    </Grid>
                </Border>

                <TextBlock Text="IVFFlat+PQ is the recommended indexing method for large datasets due to memory efficiency."
                           FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,12,0,40" HorizontalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
