<Page x:Class="DocMind.Views.Pages.Page_Library"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="My Library"
      FontFamily="{StaticResource AppFont}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <Style x:Key="FileIconStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="📄"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding FileType}" Value="PDF">
                    <Setter Property="Foreground" Value="#EF4444"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="DOCX">
                    <Setter Property="Foreground" Value="#3B82F6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="XLSX">
                    <Setter Property="Foreground" Value="#22C55E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="Image">
                    <Setter Property="Text" Value="🖼️"/>
                    <Setter Property="Foreground" Value="#F59E0B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="Code">
                    <Setter Property="Text" Value="&lt;/&gt;"/>
                    <Setter Property="Foreground" Value="#00BCD4"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="PowerPoint">
                    <Setter Property="Text" Value="📊"/>
                    <Setter Property="Foreground" Value="#D24726"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="Text">
                    <Setter Property="Text" Value="📄"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="FilterPillButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <!-- Need a way to show active filter, handled in DataTrigger below -->
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewToggleButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavActiveBgBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageFadeIn}"/>
        </EventTrigger>
    </Page.Triggers>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="Auto"/> <!-- Stats Row -->
            <RowDefinition Height="*"/>    <!-- Main Area -->
            <RowDefinition Height="Auto"/> <!-- Bottom Bar -->
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="My Library" FontSize="24" FontWeight="SemiBold" 
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                
                <!-- Filter Text -->
                <Border Background="{DynamicResource SurfaceCardBrush}" 
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" 
                        CornerRadius="8" Height="36" Margin="0,0,12,0" Width="200">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="10,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}" 
                                 VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <TextBlock x:Name="Placeholder" Text="Filter files..." Foreground="{DynamicResource TextTertiaryBrush}" Visibility="Hidden" VerticalAlignment="Center"/>
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Sort -->
                <ComboBox SelectedValue="{Binding SelectedSortOption}" SelectedValuePath="Content" Margin="0,0,12,0" Width="120" Height="36"
                          Background="{DynamicResource SurfaceCardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}">
                    <ComboBoxItem Content="Name"/>
                    <ComboBoxItem Content="Date"/>
                    <ComboBoxItem Content="Size"/>
                    <ComboBoxItem Content="Category"/>
                </ComboBox>

                <!-- View Toggle -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <RadioButton GroupName="ViewToggle" Content="▦" FontSize="18" Command="{Binding ToggleViewCommand}" CommandParameter="Grid" IsChecked="{Binding IsGridView}" Style="{StaticResource ViewToggleButton}">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,0,1" CornerRadius="4,0,0,4" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="▦" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-4,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavActiveBgBrush}"/>
                                        <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                    <RadioButton GroupName="ViewToggle" Content="☰" FontSize="18" Command="{Binding ToggleViewCommand}" CommandParameter="List" IsChecked="{Binding IsListView, Mode=OneWay}" Style="{StaticResource ViewToggleButton}">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="0,4,4,0" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="☰" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-4,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavActiveBgBrush}"/>
                                        <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </StackPanel>

                <!-- Index Button & Progress -->
                <Grid>
                    <Button Content="Index New Folder" Style="{StaticResource PrimaryButton}" Height="36" Padding="16,0" 
                            Command="{Binding IndexFolderCommand}"
                            Visibility="{Binding IsNotIndexing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    
                    <Border Background="{DynamicResource SurfaceCardBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Height="36" Padding="16,0"
                            Visibility="{Binding IsIndexing, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Indexing..." Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <ProgressBar Minimum="0" Maximum="{Binding TotalIndexedCount}" Value="{Binding IndexedCount}" Width="100" Height="4" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource BorderDefaultBrush}" BorderThickness="0" Margin="0,0,12,0"/>
                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}">
                                <Run Text="{Binding IndexedCount}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding TotalIndexedCount}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- STATS ROW -->
        <ItemsControl Grid.Row="1" Margin="0,0,0,24">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <Button Style="{StaticResource FilterPillButton}" Margin="0,0,12,0" Command="{Binding FilterCategoryCommand}" CommandParameter="All">
                <TextBlock><Run Text="All ("/><Run Text="{Binding CountAll, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
            <Button Style="{StaticResource FilterPillButton}" Margin="0,0,12,0" Command="{Binding FilterCategoryCommand}" CommandParameter="PDF">
                <TextBlock><Run Text="PDFs ("/><Run Text="{Binding CountPDF, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
            <Button Style="{StaticResource FilterPillButton}" Margin="0,0,12,0" Command="{Binding FilterCategoryCommand}" CommandParameter="DOCX">
                <TextBlock><Run Text="Word ("/><Run Text="{Binding CountWord, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
            <Button Style="{StaticResource FilterPillButton}" Margin="0,0,12,0" Command="{Binding FilterCategoryCommand}" CommandParameter="XLSX">
                <TextBlock><Run Text="Excel ("/><Run Text="{Binding CountExcel, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
            <Button Style="{StaticResource FilterPillButton}" Margin="0,0,12,0" Command="{Binding FilterCategoryCommand}" CommandParameter="Image">
                <TextBlock><Run Text="Images ("/><Run Text="{Binding CountImages, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
            <Button Style="{StaticResource FilterPillButton}" Margin="0,0,12,0" Command="{Binding FilterCategoryCommand}" CommandParameter="Code">
                <TextBlock><Run Text="Code ("/><Run Text="{Binding CountCode, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
            <Button Margin="0,0,12,0" Command="{Binding FilterCategoryCommand}" CommandParameter="PowerPoint">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterPillButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CountPowerPoint, Mode=OneWay}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock><Run Text="PowerPoint ("/><Run Text="{Binding CountPowerPoint, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
            <Button Margin="0,0,0,0" Command="{Binding FilterCategoryCommand}" CommandParameter="Text">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterPillButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CountText, Mode=OneWay}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock><Run Text="Text ("/><Run Text="{Binding CountText, Mode=OneWay}"/><Run Text=")"/></TextBlock>
            </Button>
        </ItemsControl>

        <!-- MAIN AREA -->
        <Grid Grid.Row="2">
            <!-- Grid View -->
            <ScrollViewer Style="{StaticResource SlimScrollViewer}" 
                          Visibility="{Binding IsGridView, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding FilteredFiles}" Margin="0,0,8,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}" Width="210" Height="240" Margin="0,0,16,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Loading Overlay -->
                                    <Border Grid.RowSpan="5" Background="#80000000" CornerRadius="12" Panel.ZIndex="10"
                                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="🔄" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <TextBlock Text="Generating..." Foreground="White" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Icon -->
                                    <TextBlock Grid.Row="0" Style="{StaticResource FileIconStyle}" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    
                                    <!-- Name -->
                                    <TextBlock Grid.Row="1" Text="{Binding FileName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" 
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding FileName}" TextAlignment="Center" Margin="0,0,0,4"/>
                                    
                                    <!-- Size & Pages -->
                                    <TextBlock Grid.Row="2" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextAlignment="Center" Margin="0,0,0,12">
                                        <Run Text="{Binding FileSizeKB}"/>
                                        <Run Text=" KB • "/>
                                        <Run Text="{Binding PageCount}"/>
                                        <Run Text=" pages"/>
                                    </TextBlock>
                                    
                                    <!-- Category Badge & Date -->
                                    <StackPanel Grid.Row="3" VerticalAlignment="Top" HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource AccentSubtleBrush}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Center" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource AccentHoverBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding LastModified}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" TextAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <Grid Grid.Row="4" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" ToolTip="Open" Style="{StaticResource GhostButton}" Padding="4" Margin="0,0,4,0"
                                                Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="O"/>
                                        </Button>
                                        <Button Grid.Column="1" ToolTip="Summarize" Style="{StaticResource GhostButton}" Padding="4" Margin="2,0,2,0"
                                                Command="{Binding DataContext.SummarizeCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="S"/>
                                        </Button>
                                        <Button Grid.Column="2" ToolTip="Find Similar" Style="{StaticResource GhostButton}" Padding="4" Margin="2,0,2,0"
                                                Command="{Binding DataContext.FindSimilarCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="F"/>
                                        </Button>
                                        <Button Grid.Column="3" ToolTip="Chat with File" Style="{StaticResource GhostButton}" Padding="4" Margin="4,0,0,0"
                                                Command="{Binding DataContext.ChatWithFileCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="C"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- List View -->
            <ListView ItemsSource="{Binding FilteredFiles}" Background="Transparent" BorderThickness="0" 
                      Visibility="{Binding IsListView, Converter={StaticResource BooleanToVisibilityConverter}}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border Background="{DynamicResource SurfaceCardBrush}" CornerRadius="8" Padding="12,8">
                                        <GridViewRowPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Icon" Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource FileIconStyle}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Name" Width="250">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Type" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileType}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Size" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center">
                                        <Run Text="{Binding FileSizeKB}"/><Run Text=" KB"/>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Category" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource AccentSubtleBrush}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource AccentHoverBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Date Modified" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LastModified}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Actions" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button ToolTip="Open" Style="{StaticResource GhostButton}" Padding="8,2" Margin="0,0,4,0" Height="28" Width="36"
                                                Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="O"/>
                                        </Button>
                                        <Button ToolTip="Summarize" Style="{StaticResource GhostButton}" Padding="8,2" Margin="0,0,4,0" Height="28" Width="36"
                                                Command="{Binding DataContext.SummarizeCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="S"/>
                                        </Button>
                                        <Button ToolTip="Find Similar" Style="{StaticResource GhostButton}" Padding="8,2" Margin="0,0,4,0" Height="28" Width="36"
                                                Command="{Binding DataContext.FindSimilarCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="F"/>
                                        </Button>
                                        <Button ToolTip="Chat with File" Style="{StaticResource GhostButton}" Padding="8,2" Height="28" Width="36"
                                                Command="{Binding DataContext.ChatWithFileCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                            <TextBlock Text="C"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- BOTTOM STATUS BAR -->
        <Grid Grid.Row="3" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center">
                <Run Text="Showing "/>
                <Run Text="{Binding FilteredFiles.Count, Mode=OneWay}"/>
                <Run Text=" files  •  Last indexed: "/>
                <Run Text="{Binding LastIndexedTime}"/>
            </TextBlock>
            
            <Button Grid.Column="1" Content="Re-Index" Style="{StaticResource GhostButton}" Padding="16,6" Command="{Binding IndexFolderCommand}"/>
        </Grid>
    </Grid>
</Page>
