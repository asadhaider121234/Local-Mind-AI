<Page x:Class="DocMind.Views.Pages.Page_Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:DocMind.ViewModels"
      xmlns:local="clr-namespace:DocMind.Views"
      mc:Ignorable="d" 
      d:DesignHeight="1200" d:DesignWidth="1000"
      Title="Settings"
      FontFamily="{StaticResource AppFont}">

    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Section Header Style -->
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Form Label Style -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Toggle Switch (Styled CheckBox) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="44" Height="22" CornerRadius="11" 
                                Background="{DynamicResource ToggleOffBrush}" Padding="2">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" 
                                     Fill="{DynamicResource ToggleThumbBrush}" 
                                     HorizontalAlignment="Left">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ToggleOnBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" To="22" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" To="0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Helper for RadioButton Enum binding -->
        <local:EnumToBooleanConverter x:Key="EnumToBool"/>
    </Page.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="*"/>    <!-- Settings Scroll -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Padding="32,24,32,16">
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1" Style="{StaticResource SlimScrollViewer}" Padding="32,0,32,24">
            <StackPanel>

                <!-- SECTION: MODEL SETTINGS -->
                <TextBlock Text="Model Settings" Style="{StaticResource SettingsSectionHeader}"/>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,32">
                    <StackPanel>
                        <!-- LLM Model Path -->
                        <Grid Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="LLM Model Path" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource SearchTextBox}" Text="{Binding CurrentSettings.LlmModelPath}" 
                                         IsReadOnly="True" Padding="12,10"/>
                                <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0" 
                                        Style="{StaticResource GhostButton}" Padding="16,8"
                                        Command="{Binding BrowseModelCommand}"/>
                            </Grid>
                        </Grid>

                        <!-- Vision Model Dropdown -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Vision Model" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
                                <TextBlock Text="Used for image understanding and multi-modal search" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Height="38" VerticalContentAlignment="Center"
                                      SelectedValue="{Binding CurrentSettings.VisionModel}"
                                      SelectedValuePath="Content">
                                <ComboBoxItem Content="BLIP-2 (Recommended)"/>
                                <ComboBoxItem Content="LLaVA"/>
                                <ComboBoxItem Content="Disabled"/>
                            </ComboBox>
                        </Grid>

                        <!-- CPU Threads Slider -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU Threads" Style="{StaticResource FormLabel}"/>
                            <Slider Grid.Column="1" Minimum="1" Maximum="16" IsSnapToTickEnabled="True" TickFrequency="1" 
                                    Value="{Binding CurrentSettings.CpuThreads}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding CurrentSettings.CpuThreads}" 
                                       HorizontalAlignment="Right" VerticalAlignment="Center" 
                                       FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </Grid>

                        <!-- Context Length Dropdown -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Context Length" Style="{StaticResource FormLabel}"/>
                            <ComboBox Grid.Column="1" Height="38" VerticalContentAlignment="Center"
                                      SelectedValue="{Binding CurrentSettings.ContextLength}">
                                <System:Int32 xmlns:System="clr-namespace:System;assembly=mscorlib">2048</System:Int32>
                                <System:Int32 xmlns:System="clr-namespace:System;assembly=mscorlib">4096</System:Int32>
                                <System:Int32 xmlns:System="clr-namespace:System;assembly=mscorlib">8192</System:Int32>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: INDEXING SETTINGS -->
                <TextBlock Text="Indexing Settings" Style="{StaticResource SettingsSectionHeader}"/>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,32">
                    <StackPanel>
                        <!-- Watched Folders -->
                        <TextBlock Text="Watched Folders" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding WatchedFolders}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="6" Padding="12,8">
                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="✕" Margin="8,0,0,0" Width="32" Height="32"
                                                Style="{StaticResource GhostButton}" Padding="0" Foreground="{DynamicResource StatusRedBrush}"
                                                Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Folder" Style="{StaticResource GhostButton}" 
                                HorizontalAlignment="Left" Command="{Binding AddFolderCommand}" Margin="0,0,0,24"/>

                        <!-- Chunk Size Slider -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Chunk Size (words)" Style="{StaticResource FormLabel}"/>
                            <Slider Grid.Column="1" Minimum="100" Maximum="800" IsSnapToTickEnabled="True" TickFrequency="50" 
                                    Value="{Binding CurrentSettings.ChunkSize}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding CurrentSettings.ChunkSize}" Width="40"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" 
                                       FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </Grid>

                        <!-- Auto Re-index Toggle -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Auto Re-index on File Change" Style="{StaticResource FormLabel}"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding CurrentSettings.AutoReindex}" Style="{StaticResource ToggleSwitch}"/>
                        </Grid>

                        <!-- File Types -->
                        <TextBlock Text="File types to index" Style="{StaticResource FormLabel}" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Documents &amp; Images" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                        <WrapPanel Margin="0,0,0,16">
                            <CheckBox Content="PDF" IsChecked="{Binding CurrentSettings.IndexPdf}" Margin="0,0,16,8"/>
                            <CheckBox Content="DOCX" IsChecked="{Binding CurrentSettings.IndexDocx}" Margin="0,0,16,8"/>
                            <CheckBox Content="XLSX" IsChecked="{Binding CurrentSettings.IndexXlsx}" Margin="0,0,16,8"/>
                            <CheckBox Content="TXT" IsChecked="{Binding CurrentSettings.IndexTxt}" Margin="0,0,16,8"/>
                            <CheckBox Content="CSV" IsChecked="{Binding CurrentSettings.IndexCsv}" Margin="0,0,16,8"/>
                            <CheckBox Content="JPG" IsChecked="{Binding CurrentSettings.IndexJpg}" Margin="0,0,16,8"/>
                            <CheckBox Content="PNG" IsChecked="{Binding CurrentSettings.IndexPng}" Margin="0,0,16,8"/>
                            <CheckBox Content="PPTX" IsChecked="{Binding CurrentSettings.IndexPptx}" Margin="0,0,16,8"/>
                            <CheckBox Content="RTF" IsChecked="{Binding CurrentSettings.IndexRtf}" Margin="0,0,16,8"/>
                            <CheckBox Content="MD" IsChecked="{Binding CurrentSettings.IndexMd}" Margin="0,0,16,8"/>
                            <CheckBox Content="LOG" IsChecked="{Binding CurrentSettings.IndexLog}" Margin="0,0,16,8"/>
                        </WrapPanel>

                        <TextBlock Text="Code Files" FontSize="11" Foreground="#00BCD4" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <CheckBox Content="PY" IsChecked="{Binding CurrentSettings.IndexPY}" Margin="0,0,16,8"/>
                            <CheckBox Content="CS" IsChecked="{Binding CurrentSettings.IndexCS}" Margin="0,0,16,8"/>
                            <CheckBox Content="CPP" IsChecked="{Binding CurrentSettings.IndexCPP}" Margin="0,0,16,8"/>
                            <CheckBox Content="JS" IsChecked="{Binding CurrentSettings.IndexJS}" Margin="0,0,16,8"/>
                            <CheckBox Content="HTML" IsChecked="{Binding CurrentSettings.IndexHTML}" Margin="0,0,16,8"/>
                            <CheckBox Content="CSS" IsChecked="{Binding CurrentSettings.IndexCSS}" Margin="0,0,16,8"/>
                            <CheckBox Content="JSON" IsChecked="{Binding CurrentSettings.IndexJSON}" Margin="0,0,16,8"/>
                            <CheckBox Content="XML" IsChecked="{Binding CurrentSettings.IndexXML}" Margin="0,0,16,8"/>
                            <CheckBox Content="SQL" IsChecked="{Binding CurrentSettings.IndexSQL}" Margin="0,0,16,8"/>
                            <CheckBox Content="XAML" IsChecked="{Binding CurrentSettings.IndexXAML}" Margin="0,0,16,8"/>
                            <CheckBox Content="IPYNB" IsChecked="{Binding CurrentSettings.IndexIPYNB}" Margin="0,0,16,8"/>
                        </WrapPanel>

                    </StackPanel>
                </Border>

                <!-- SECTION: SEARCH SETTINGS -->
                <TextBlock Text="Search Settings" Style="{StaticResource SettingsSectionHeader}"/>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,32">
                    <StackPanel>
                        <!-- Results per query slider -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Results per query (k)" Style="{StaticResource FormLabel}"/>
                            <Slider Grid.Column="1" Minimum="1" Maximum="10" IsSnapToTickEnabled="True" TickFrequency="1" 
                                    Value="{Binding CurrentSettings.ResultsPerQuery}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding CurrentSettings.ResultsPerQuery}" 
                                       HorizontalAlignment="Right" VerticalAlignment="Center" 
                                       FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </Grid>

                        <!-- Hallucination Filter Toggle -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Enable hallucination filter" Style="{StaticResource FormLabel}"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding CurrentSettings.EnableHallucinationFilter}" Style="{StaticResource ToggleSwitch}"/>
                        </Grid>

                        <!-- Image Search Toggle -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Enable image search" Style="{StaticResource FormLabel}"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding CurrentSettings.EnableImageSearch}" Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: BACKEND / API -->
                <TextBlock Text="Backend / API" Style="{StaticResource SettingsSectionHeader}"/>
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,32">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="API Host &amp; Port" Style="{StaticResource FormLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Gray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource StatusGreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource StatusRedBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Unknown Status"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Text" Value="Connected"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                        <Setter Property="Text" Value="Not connected"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            <TextBox Grid.Column="1" Style="{StaticResource SearchTextBox}" Text="{Binding CurrentSettings.ApiHost}" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="2" Width="80" Style="{StaticResource SearchTextBox}" Text="{Binding CurrentSettings.ApiPort}"/>
                        </Grid>
                        <Button Content="Test Connection" Style="{StaticResource GhostButton}" 
                                HorizontalAlignment="Left" Command="{Binding TestConnectionCommand}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM ACTIONS -->
        <Border Grid.Row="2" Background="{DynamicResource TopBarBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0"
                Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Content="Reset to Defaults" Style="{StaticResource GhostButton}" 
                        Command="{Binding ResetDefaultsCommand}"/>
                
                <!-- Toast Notification -->
                <Border Grid.Column="1" Background="#0D2010" BorderBrush="#166534" BorderThickness="1" 
                        CornerRadius="6" Padding="12,6" HorizontalAlignment="Center" 
                        Visibility="{Binding ShowSavedToast, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Settings saved ✓" Foreground="#22C55E" FontSize="13" FontWeight="SemiBold"/>
                </Border>

                <Button Grid.Column="2" Content="Save Settings" Style="{StaticResource PrimaryButton}" 
                        Width="200" Command="{Binding SaveSettingsCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
