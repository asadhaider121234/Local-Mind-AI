<Page x:Class="DocMind.Views.Pages.Page_Categories"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DocMind.Views"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Categories"
      FontFamily="{StaticResource AppFont}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:HexToBrushConverter x:Key="HexToBrushConverter"/>

        <!-- Invert boolean to visibility converter -->
        <Style x:Key="InverseVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCategorySelected}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryCardRadioButton" TargetType="RadioButton">
            <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="CategoriesGroup"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavActiveBgBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reusing FileIconStyle from Library Page logic -->
        <Style x:Key="FileIconStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="📄"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding FileType}" Value="PDF">
                    <Setter Property="Foreground" Value="#EF4444"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="DOCX">
                    <Setter Property="Foreground" Value="#3B82F6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="XLSX">
                    <Setter Property="Foreground" Value="#22C55E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="Image">
                    <Setter Property="Text" Value="🖼️"/>
                    <Setter Property="Foreground" Value="#F59E0B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding FileType}" Value="Code">
                    <Setter Property="Text" Value="&lt;/&gt;"/>
                    <Setter Property="Foreground" Value="#00BCD4"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageFadeIn}"/>
        </EventTrigger>
    </Page.Triggers>

    <Grid Margin="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="32"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Categories" FontSize="24" FontWeight="SemiBold" 
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <ScrollViewer Grid.Row="1" Style="{StaticResource SlimScrollViewer}">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Style="{StaticResource CategoryCardRadioButton}"
                                         Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                         CommandParameter="{Binding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Row="0" Grid.Column="0" Width="40" Height="40" CornerRadius="8" 
                                            Background="{DynamicResource SurfaceCardBrush}" Margin="0,0,12,0"
                                            BorderThickness="1" BorderBrush="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                        <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Name -->
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" FontSize="16" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                                    <!-- Count Badge -->
                                    <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource BorderSubtleBrush}" CornerRadius="12" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                                            <Run Text="{Binding FileCount, Mode=OneWay}"/>
                                            <Run Text=" files"/>
                                        </TextBlock>
                                    </Border>

                                    <!-- Proportion Bar -->
                                    <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Minimum="0" Maximum="1" Value="{Binding Proportion}" 
                                                 Height="4" Margin="0,16,0,0" BorderThickness="0" Background="{DynamicResource BorderDefaultBrush}"
                                                 Foreground="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"/>
                                </Grid>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="2">
            <!-- Empty State (No Category Selected or Category is Empty) -->
            <Border Style="{StaticResource CardBorder}" 
                    Visibility="{Binding IsCategorySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- Inner content only visible if there are 0 files -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilteredFiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📂" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="No files in this category yet" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Documents are categorized automatically when indexed" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Please Select a Category Overlay -->
            <Border Visibility="{Binding IsCategorySelected, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardBorder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCategorySelected}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="👈" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Select a category" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Choose a category from the left to view files" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content Area (Visible when Category is selected AND has files) -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCategorySelected}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FilteredFiles.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16">
                        <Run Text="All Categories" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Run Text="  >  " Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <Run Text="{Binding SelectedCategory.Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </TextBlock>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Search Box -->
                        <Border Background="{DynamicResource SurfaceCardBrush}" 
                                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" 
                                CornerRadius="8" Height="36" Margin="0,0,12,0" Width="200">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="10,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}" 
                                         VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBlock x:Name="Placeholder" Text="Search..." Foreground="{DynamicResource TextTertiaryBrush}" Visibility="Hidden" VerticalAlignment="Center"/>
                                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Border>

                        <!-- Sort -->
                        <ComboBox SelectedValue="{Binding SelectedSortOption}" SelectedValuePath="Content" Margin="0,0,16,0" Width="100" Height="36"
                                  Background="{DynamicResource SurfaceCardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}">
                            <ComboBoxItem Content="Name"/>
                            <ComboBoxItem Content="Date"/>
                            <ComboBoxItem Content="Size"/>
                        </ComboBox>

                        <!-- Count -->
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding FilteredFiles.Count, Mode=OneWay}"/>
                            <Run Text=" files"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Document List -->
                <ScrollViewer Grid.Row="1" Style="{StaticResource SlimScrollViewer}">
                    <ItemsControl ItemsSource="{Binding FilteredFiles}" Margin="0,0,8,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceCardBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1" Padding="16" Margin="0,0,0,8" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <TextBlock Grid.Column="0" Style="{StaticResource FileIconStyle}" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                        <!-- Name & Tags -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding FileName}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0" FontSize="14"/>
                                                <TextBlock Text="{Binding FilePath}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="{DynamicResource BorderSubtleBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding FileType}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                                <Border Background="{DynamicResource BorderSubtleBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                        <Run Text="{Binding PageCount}"/> pages
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="{DynamicResource BorderSubtleBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                        <Run Text="{Binding FileSizeKB}"/> KB
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="{DynamicResource AccentSubtleBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                        Visibility="{Binding IsIndexed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Indexed" FontSize="11" Foreground="{DynamicResource AccentHoverBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Date -->
                                        <TextBlock Grid.Column="2" Text="{Binding LastModified}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,24,0"/>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Open" Style="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,8,0" Height="32"
                                                    Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}"/>
                                            <Button Content="Summarize" Style="{StaticResource GhostButton}" Padding="12,6" Margin="0,0,8,0" Height="32"
                                                    Command="{Binding DataContext.SummarizeCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}"/>
                                            <Button Content="Move to..." Style="{StaticResource GhostButton}" Padding="12,6" Height="32"
                                                    Command="{Binding DataContext.MoveToCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
