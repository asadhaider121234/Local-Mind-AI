<Page x:Class="DocMind.Views.Pages.Page_Search"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Search"
      FontFamily="{StaticResource AppFont}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageFadeIn}"/>
        </EventTrigger>
    </Page.Triggers>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Search Bar -->
            <RowDefinition Height="Auto"/> <!-- Stats Bar -->
            <RowDefinition Height="*"/>    <!-- Results -->
        </Grid.RowDefinitions>

        <!-- SECTION 1: SEARCH BAR -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <Grid Margin="0,0,0,16">
                <TextBlock Text="Search" FontSize="20" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                
                <!-- File Context Badge -->
                <Border HorizontalAlignment="Right" Background="{DynamicResource AccentSubtleBrush}" 
                        CornerRadius="14" Padding="12,6"
                        Visibility="{Binding IsInFileContext, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Chatting with: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FileContextName}" Foreground="{DynamicResource AccentHoverBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource GhostButton}" Margin="8,0,0,0" Padding="4,0"
                                Command="{Binding ClearContextCommand}">
                            <TextBlock Text="✕" FontSize="10" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
            
            <Border Background="{DynamicResource SurfaceCardBrush}" 
                    BorderBrush="{DynamicResource BorderDefaultBrush}" 
                    BorderThickness="1" CornerRadius="26" Height="52">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" Margin="20,0,10,0"/>
                    
                    <TextBox x:Name="SearchBox" Grid.Column="1" 
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0" 
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="16" VerticalAlignment="Center"
                             KeyDown="SearchBox_KeyDown"
                             Tag="Ask anything about your documents... e.g. 'What was my electricity bill in March?'">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <TextBlock x:Name="Placeholder" Text="{TemplateBinding Tag}" 
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           Visibility="Hidden"
                                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4">
                        <!-- Search Button -->
                        <Button Width="44" Height="44" Command="{Binding SearchCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{DynamicResource AccentBrush}" CornerRadius="22">
                                                    <TextBlock Text="➔" Foreground="White" FontSize="18" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <!-- Stop Button -->
                        <Button Width="44" Height="44" Command="{Binding StopCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#e53935" CornerRadius="22">
                                                    <TextBlock Text="■" Foreground="White" FontSize="18" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <ItemsControl Margin="16,12,0,0" ItemsSource="{Binding Suggestions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Height="28" Padding="12,0" 
                                Command="{Binding DataContext.SuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- Loading Bar -->
            <ProgressBar IsIndeterminate="True" Height="2" Margin="0,16,0,0" 
                         Foreground="{DynamicResource AccentBrush}" 
                         Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <!-- SECTION 2: STATS BAR -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1 -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="📄 Total Files" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TotalFiles, StringFormat=\{0:N0\}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            
            <!-- Card 2 -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="8,0,8,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="🧠 Indexed Chunks" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding IndexedChunks, StringFormat=\{0:N0\}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Card 3 -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="8,0,8,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="⚡ Last Query" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LastQueryTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Card 4 -->
            <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="8,0,0,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="📅 Last Indexed" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LastIndexed}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SECTION 3: RESULTS AREA -->
        <Grid Grid.Row="2">
            <!-- Empty State -->
            <Border Style="{StaticResource CardBorder}" 
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="64" Foreground="{DynamicResource BorderStrongBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Your documents are ready" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Ask a question in natural language above" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Loading Skeletons -->
            <StackPanel Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="{DynamicResource SurfaceCardBrush}" CornerRadius="12" Height="140" Margin="0,0,0,16" Opacity="0.5"/>
                <Border Background="{DynamicResource SurfaceCardBrush}" CornerRadius="12" Height="100" Margin="0,0,0,12" Opacity="0.3"/>
                <Border Background="{DynamicResource SurfaceCardBrush}" CornerRadius="12" Height="100" Margin="0,0,0,12" Opacity="0.2"/>
            </StackPanel>

            <!-- Results State -->
            <ScrollViewer x:Name="ChatScrollViewer" Style="{StaticResource SlimScrollViewer}" 
                          Visibility="{Binding HasHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="0,0,12,0">
                    
                    <!-- SECTION A: Chat History Header -->
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Chat History" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Content="Clear Chat" Command="{Binding ClearChatCommand}" 
                                HorizontalAlignment="Right" Padding="12,4" 
                                Foreground="#e53935" BorderBrush="#e53935" BorderThickness="1" Background="Transparent" />
                    </Grid>

                    <!-- Chat History List -->
                    <ItemsControl ItemsSource="{Binding ChatHistory}" Margin="0,0,0,32">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,16">
                                    <Border x:Name="MessageBorder" Padding="16" CornerRadius="12" MaxWidth="700">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock x:Name="AvatarText" FontSize="16" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="RoleText" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                                <Border x:Name="ModeBadge" CornerRadius="12" Padding="8,2" Margin="12,0,0,0" Visibility="Collapsed">
                                                    <TextBlock x:Name="ModeText" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            
                                            <TextBlock Text="{Binding Content}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" LineHeight="22" FontSize="14"/>
                                            
                                            <TextBlock x:Name="TimeText" Text="{Binding Timestamp, StringFormat='{}{0:MMM d, h:mm tt}'}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <!-- User styling -->
                                    <DataTrigger Binding="{Binding Role}" Value="user">
                                        <Setter TargetName="MessageBorder" Property="HorizontalAlignment" Value="Right"/>
                                        <Setter TargetName="MessageBorder" Property="Background" Value="#1e3a5f"/>
                                        <Setter TargetName="AvatarText" Property="Text" Value="👤"/>
                                        <Setter TargetName="RoleText" Property="Text" Value="You"/>
                                        <Setter TargetName="RoleText" Property="Foreground" Value="#a0c0e0"/>
                                        <Setter TargetName="TimeText" Property="HorizontalAlignment" Value="Right"/>
                                    </DataTrigger>
                                    
                                    <!-- Assistant styling -->
                                    <DataTrigger Binding="{Binding Role}" Value="assistant">
                                        <Setter TargetName="MessageBorder" Property="HorizontalAlignment" Value="Left"/>
                                        <Setter TargetName="MessageBorder" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                        <Setter TargetName="AvatarText" Property="Text" Value="🧠"/>
                                        <Setter TargetName="RoleText" Property="Text" Value="DocMind"/>
                                        <Setter TargetName="RoleText" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="TimeText" Property="HorizontalAlignment" Value="Left"/>
                                    </DataTrigger>
                                    
                                    <!-- Badges for assistant -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Role}" Value="assistant"/>
                                            <Condition Binding="{Binding Mode}" Value="document"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="ModeBadge" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="ModeBadge" Property="Background" Value="#e6f0fa"/>
                                        <Setter TargetName="ModeText" Property="Text" Value="📄 DOC"/>
                                        <Setter TargetName="ModeText" Property="Foreground" Value="#005fb8"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Role}" Value="assistant"/>
                                            <Condition Binding="{Binding Mode}" Value="general"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="ModeBadge" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="ModeBadge" Property="Background" Value="#f3e5f5"/>
                                        <Setter TargetName="ModeText" Property="Text" Value="🤖 AI"/>
                                        <Setter TargetName="ModeText" Property="Foreground" Value="#7b1fa2"/>
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- SECTION B: Current Answer & Sources -->
                    <StackPanel Visibility="{Binding ShowResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- Answer Card -->
                        <Border Background="{DynamicResource SurfaceElevatedBrush}" 
                                BorderBrush="{DynamicResource AccentBrush}" 
                                BorderThickness="4,0,0,0" CornerRadius="4,8,8,4" Padding="20" Margin="0,0,0,24">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="AI ANSWER" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <Button x:Name="CopyAnswerButton"
                                            HorizontalAlignment="Right"
                                            Click="CopyAnswer_Click"
                                            Padding="10,4"
                                            Cursor="Hand"
                                            ToolTip="Copy answer to clipboard">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Root"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSubtleBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="CopyIcon" Text="📋" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock x:Name="CopyLabel" Text="Copy" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBlock Text="{Binding CurrentAnswer.AnswerText}" FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" LineHeight="24" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="Sources used:" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding CurrentAnswer.Sources}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceCardBrush}" 
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                                    CornerRadius="14" Padding="12,6" Margin="0,0,8,8">
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                                                    <Run Text="📄 "/>
                                                    <Run Text="{Binding FileName}"/>
                                                    <Run Text=" • Page "/>
                                                    <Run Text="{Binding PageNumber}"/>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
    
                        <!-- Source Chunks Header -->
                        <TextBlock Text="Retrieved Passages" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <!-- Source Chunks List -->
                        <ItemsControl ItemsSource="{Binding Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
    
                                            <!-- Top Row: File Info & Badge -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,12">
                                                <TextBlock Text="📄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding FileName}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text=" • Page " Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding PageNumber}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                
                                                <!-- Category Badge -->
                                                <Border Background="{DynamicResource AccentSubtleBrush}" CornerRadius="12" Padding="8,2" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource AccentHoverBrush}"/>
                                                </Border>
                                            </StackPanel>
    
                                            <!-- Open File Button -->
                                            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource GhostButton}" Padding="12,6" VerticalAlignment="Top">
                                                <TextBlock Text="Open File" FontSize="12"/>
                                            </Button>
    
                                            <!-- Excerpt -->
                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                                       Text="{Binding Excerpt}" Foreground="{DynamicResource TextSecondaryBrush}" 
                                                       TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,12"/>
    
                                            <!-- Relevance Bar -->
                                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                                <!-- Simplified progress bar since standard WPF doesn't have CornerRadius for it out of box easily -->
                                                <ProgressBar Value="{Binding RelevanceScore}" Maximum="1" Height="4" 
                                                             Background="{DynamicResource BorderDefaultBrush}"
                                                             Foreground="{DynamicResource StatusGreenBrush}" 
                                                             BorderThickness="0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
