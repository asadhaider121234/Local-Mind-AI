<Window x:Class="DocMind.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DocMind.ViewModels"
        mc:Ignorable="d"
        Title="DocMind — Offline AI Search" 
        Height="800" Width="1280"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFont}">
    
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="6" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                    <TextBlock Text="DocMind" FontWeight="SemiBold" VerticalAlignment="Center" 
                               Foreground="{DynamicResource TitleBarForegroundBrush}" FontSize="12"/>
                </StackPanel>

                <!-- Drag region -->
                <Border Grid.Column="1" Background="Transparent" WindowChrome.IsHitTestVisibleInChrome="False"/>

                <!-- Window Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="─" Style="{StaticResource ChromeButton}" Click="Minimize_Click"/>
                    <Button Content="◻" Style="{StaticResource ChromeButton}" Click="Maximize_Click" FontSize="14"/>
                    <Button Content="✕" Style="{StaticResource ChromeCloseButton}" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STATUS BANNER -->
        <Border Grid.Row="1" Background="#FFE5E5" BorderBrush="#FF4D4D" BorderThickness="0,0,0,1" 
                Visibility="{Binding IsBackendOffline, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="⚠ Backend offline — start the Python server to use DocMind" 
                       Foreground="#D8000C" FontWeight="SemiBold" FontSize="14" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8"/>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" x:Name="SidebarColumn"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Branding -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,32,24,32">
                        <TextBlock Text="🧠" FontSize="24" Margin="0,0,12,0"/>
                        <TextBlock Text="DocMind" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" x:Name="BrandText"/>
                    </StackPanel>

                    <!-- Nav Menu -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding NavItems}" Margin="12,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource NavItemButton}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal" Margin="8,0">
                                        <TextBlock Text="{Binding Icon}" FontSize="18" Width="32" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                                   Foreground="{Binding IsSelected, Converter={StaticResource SelectedToColorConverter}}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Margin="24,24,24,32">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentIndexStatus}" Value="Ready">
                                                <Setter Property="Fill" Value="{DynamicResource StatusGreenBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentIndexStatus}" Value="Indexing">
                                                <Setter Property="Fill" Value="{DynamicResource StatusOrangeBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentIndexStatus}" Value="NotIndexed">
                                                <Setter Property="Fill" Value="{DynamicResource StatusRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentIndexStatus}" Value="Ready">
                                                <Setter Property="Text" Value="Index Ready"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentIndexStatus}" Value="Indexing">
                                                <Setter Property="Text" Value="Indexing..."/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentIndexStatus}" Value="NotIndexed">
                                                <Setter Property="Text" Value="Not Indexed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding AppVersion}" FontSize="12" Foreground="{DynamicResource TextDisabledBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT CONTENT AREA -->
            <Grid Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="72"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Grid Grid.Row="0" Margin="32,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Theme Toggle -->
                        <ToggleButton Style="{StaticResource ThemeToggleButton}" 
                                      IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"/>
                    </StackPanel>
                </Grid>

                <!-- Page Frame -->
                <Frame Grid.Row="1" x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="0" ClipToBounds="True"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
