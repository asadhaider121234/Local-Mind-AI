<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  LIGHT THEME COLOR PALETTE                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <Color x:Key="WindowBackgroundColor">#F5F6FA</Color>
    <Color x:Key="SidebarBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SurfaceCardColor">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedColor">#EEF0F8</Color>
    <Color x:Key="TopBarBackgroundColor">#FFFFFF</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#2563EB</Color>
    <Color x:Key="AccentHoverColor">#1D4ED8</Color>
    <Color x:Key="AccentPressedColor">#1E40AF</Color>
    <Color x:Key="AccentSubtleColor">#DBEAFE</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <Color x:Key="TextTertiaryColor">#9CA3AF</Color>
    <Color x:Key="TextDisabledColor">#D1D5DB</Color>

    <!-- Borders -->
    <Color x:Key="BorderSubtleColor">#F3F4F6</Color>
    <Color x:Key="BorderDefaultColor">#E5E7EB</Color>
    <Color x:Key="BorderStrongColor">#D1D5DB</Color>

    <!-- Status -->
    <Color x:Key="StatusGreenColor">#16A34A</Color>
    <Color x:Key="StatusOrangeColor">#D97706</Color>
    <Color x:Key="StatusRedColor">#DC2626</Color>

    <!-- Nav -->
    <Color x:Key="NavActiveColor">#2563EB</Color>
    <Color x:Key="NavActiveBgColor">#DBEAFE</Color>
    <Color x:Key="NavHoverBgColor">#F3F4F6</Color>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  BRUSHES                                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCardColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="{StaticResource TopBarBackgroundColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>

    <SolidColorBrush x:Key="StatusGreenBrush" Color="{StaticResource StatusGreenColor}"/>
    <SolidColorBrush x:Key="StatusOrangeBrush" Color="{StaticResource StatusOrangeColor}"/>
    <SolidColorBrush x:Key="StatusRedBrush" Color="{StaticResource StatusRedColor}"/>

    <SolidColorBrush x:Key="NavActiveBgBrush" Color="{StaticResource NavActiveBgColor}"/>
    <SolidColorBrush x:Key="NavHoverBgBrush" Color="{StaticResource NavHoverBgColor}"/>
    <SolidColorBrush x:Key="NavActiveIndicatorBrush" Color="{StaticResource NavActiveColor}"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#F3F4F6"/>

    <!-- Toggle Switch -->
    <SolidColorBrush x:Key="ToggleOffBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="ToggleOnBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ToggleThumbBrush" Color="#FFFFFF"/>

    <!-- TitleBar -->
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#6B7280"/>

    <!-- Theme name key for identification -->
    <sys:String x:Key="ThemeName" xmlns:sys="clr-namespace:System;assembly=mscorlib">Light</sys:String>

</ResourceDictionary>
